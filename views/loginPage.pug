
extends ./baseLayout.pug


block content
	form(class="d-float" action='/auth' method='POST')
		.my-3.col-md-6
			h1 Login

		.my-3.col-md-6
			label.form-label(for='usr') Username
			input#usr.form-control(type='text' name='usr' required='')
			
		.my-3.col-md-6
			label.form-label(for='pwd') Password
			input#pwd.form-control(type='password' name='pwd' required='')
		
		.my-4.col-md-6
			button.btn.btn-primary(type='submit') Login
		
		p
			| If you don&apos;t have an account, 
			a(href='/signup') click here to sign up
			| !
