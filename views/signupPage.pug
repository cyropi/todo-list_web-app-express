
extends ./baseLayout.pug


block content 
	form(class="d-float" action='/signup' method='POST')
		.my-3.col-md-6
			h1 Sign up
		
		.my-3.col-md-6
			label(class="form-label" for='usr') Username
			input#usr.form-control(type='text' name='usr' required='')
		
		.my-3.col-md-6
			label.form-label(for='pwd') Password
			input#pwd.form-control(type='password' name='pwd' required='')

		.my-4.col-md-6
			button.btn.btn-primary(type='submit') Sign up
		
		p
			| If you already have an account, 
			a(href='/auth') click here to sign in
			| !
